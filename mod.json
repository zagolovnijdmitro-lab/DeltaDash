{
	"geode": "5.4.0",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "zagolovnijdimitro.deltadash",
	"name": "DeltaDash",
	"version": "v1.1.0",
	"developers": ["Saritahhh", "Erymanthus", "zagolovnijdimitro-lab"],
	"description": "Bring aspects from Deltarune to GD! Ported to Geode v5.",
	"tags": ["gameplay", "interface", "customization"],
	"settings": {
		"enable-deltarune": {
			"type": "bool",
			"name": "Enable DeltaDash",
			"description": "Enables/Disables the mod.",
			"default": true
		},
		"activation-mode": {
			"type": "string",
			"name": "Activation Mode",
			"description": "Defines when to activate Battle Mode.\n- 'On Start': immediately.\n- 'Mid-Game Keybind': toggle with Q.",
			"default": "on-start",
			"one-of": ["on-start", "midgame-keybind"]
		},
		"party-char1": {
			"type": "string",
			"name": "Party - Character 1",
			"description": "The character to use in the Deltarune styled tab.",
			"default": "kris",
			"one-of": ["kris", "susie", "ralsei", "noelle", "player", "true-player"]
		},
		"party-char2": {
			"type": "string",
			"name": "Party - Character 2",
			"default": "susie",
			"one-of": ["kris", "susie", "ralsei", "noelle", "player", "none"]
		},
		"party-char3": {
			"type": "string",
			"name": "Party - Character 3",
			"default": "ralsei",
			"one-of": ["kris", "susie", "ralsei", "noelle", "player", "none"]
		},
		"enable-soul": {
			"type": "bool",
			"name": "Soul Mode",
			"description": "Replaces the player icon with the soul.",
			"default": false
		},
		"soulmode-keepat0rot": {
			"type": "bool",
			"name": "Soul Mode - Keep Soul Upright",
			"default": false,
			"enable-if": "enable-soul"
		},
		"soulmode-colormode": {
			"type": "string",
			"name": "Soul Mode - Color Mode",
			"default": "GD Color",
			"one-of": ["GD Color", "UTDR Color"],
			"enable-if": "enable-soul"
		},
		"soulmode-static-color": {
			"type": "bool",
			"name": "Soul Mode - Static Color",
			"default": false,
			"enable-if": "enable-soul"
		},
		"ui-scale": {
			"type": "float",
			"name": "UI Scale - Party UI",
			"default": 1.0,
			"min": 0.1,
			"max": 1.0
		},
		"graze-scale": {
			"type": "float",
			"name": "Graze Effect Scale",
			"default": 1.5,
			"min": 1.0,
			"max": 3.0
		},
		"always-imitate-deltarune-pos": {
			"type": "bool",
			"name": "Always Imitate Deltarune X Position",
			"default": false
		}
	},
	"resources": {
		"files": [
			"resources/*.ogg",
			"resources/fonts/*.png",
			"resources/fonts/*.fnt",
			"resources/animated/*.gif"
		],
		"spritesheets": {
			"DeltaruneSheet": [
				"resources/deltarune/*.png"
			]
		},
		"sprites": [
			"resources/*.png"
		]
	},
	"dependencies": [
		{ "id": "geode.node-ids", "version": ">=v1.23.3", "importance": "required" },
		{ "id": "prevter.imageplus", "version": ">=v1.1.0", "importance": "required" },
		{ "id": "geode.custom-keybinds", "version": ">=v2.0.0", "importance": "required" },
		{ "id": "hiimjustin000.more_icons", "version": ">=v1.16.2", "importance": "required" }
	]
}
